{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with medical identity indicators",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "trustIdActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    },
    "Prescription": {
      "title": "Medical Prescription (NFT-like)",
      "description": "Cross-border medical prescription stored on-chain (conceptually)",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "medication": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "stellarAssetId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "used"] }
      },
      "required": ["patientId", "medication", "validUntil"]
    },
    "Pickup": {
      "title": "Medicine Pickup Token",
      "description": "Token generated for medicine withdrawal at a dispensary",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "dispensaryId": { "type": "string" },
        "strain": { "type": "object" },
        "quantity": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "token": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "dispensaryId", "token"]
    },
    "DoctorApplication": {
      "title": "Doctor Application",
      "description": "Private professional onboarding request reviewed by Trust Leaf admin before on-chain registry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "licenseId": { "type": "string" },
        "specialty": { "type": "string" },
        "contact": { "type": "string" },
        "wallet": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "needs_review", "approved", "rejected"] },
        "onchainStatus": { "type": "string", "enum": ["pending", "registered", "failed"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "metadataHash": { "type": "string" }
      },
      "required": ["id", "name", "licenseId", "specialty", "contact", "wallet", "status", "onchainStatus", "submittedAt"]
    },
    "DispensaryApplication": {
      "title": "Dispensary Application",
      "description": "Private dispensary onboarding request reviewed by Trust Leaf admin before on-chain registry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "legalId": { "type": "string" },
        "address": { "type": "string" },
        "contact": { "type": "string" },
        "wallet": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "needs_review", "approved", "rejected"] },
        "onchainStatus": { "type": "string", "enum": ["pending", "registered", "failed"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "metadataHash": { "type": "string" }
      },
      "required": ["id", "name", "legalId", "address", "contact", "wallet", "status", "onchainStatus", "submittedAt"]
    },
    "ClinicalRecord": {
      "title": "Private Clinical Record",
      "description": "Encrypted/off-chain patient history, symptoms, exams and treatment evidence",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "recordType": { "type": "string", "enum": ["symptoms", "exam", "treatment", "note"] },
        "privatePayloadRef": { "type": "string" },
        "publicHash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "recordType", "privatePayloadRef", "createdAt"]
    },
    "ConsentGrant": {
      "title": "Patient Consent Grant",
      "description": "Temporary patient permission for a doctor or validator to read scoped private records",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "actorWallet": { "type": "string" },
        "actorRole": { "type": "string", "enum": ["doctor", "dispensary", "admin", "validator"] },
        "scope": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "revoked", "expired"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "publicHash": { "type": "string" }
      },
      "required": ["patientId", "actorWallet", "actorRole", "scope", "status", "expiresAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user data"
    },
    "prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Medical prescriptions"
    },
    "pickups/{pickupId}": {
      "schema": "Pickup",
      "description": "Active medicine withdrawals"
    },
    "doctorApplications/{applicationId}": {
      "schema": "DoctorApplication",
      "description": "Doctor onboarding applications and admin review state"
    },
    "dispensaryApplications/{applicationId}": {
      "schema": "DispensaryApplication",
      "description": "Dispensary onboarding applications and admin review state"
    },
    "clinicalRecords/{recordId}": {
      "schema": "ClinicalRecord",
      "description": "Private patient clinical history and exam references"
    },
    "consents/{consentId}": {
      "schema": "ConsentGrant",
      "description": "Temporary patient-controlled access grants"
    }
  }
}

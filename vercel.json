{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "soroban/target/wasm32v1-none/release/*.wasm"
    }
  },
  "rewrites": [
    {
      "source": "/paciente",
      "destination": "/index.html"
    },
    {
      "source": "/paciente/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/medico",
      "destination": "/index.html"
    },
    {
      "source": "/medico/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/dispensario",
      "destination": "/index.html"
    },
    {
      "source": "/dispensario/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/mvp",
      "destination": "/index.html"
    },
    {
      "source": "/mvp/:path*",
      "destination": "/index.html"
    }
  ]
}
